        let node = &ir.nodes[0];
        assert_eq!(node.style_tag_uuids.len(), 2);
        assert!(node
            .style_tag_uuids
            .iter()
            .any(|uuid| uuid == "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"));
        assert!(node
            .style_tag_uuids
            .iter()
            .any(|uuid| uuid == "1477f18d-9b3e-4e5c-8047-dc60ba606ddb"));
    }

    #[test]
