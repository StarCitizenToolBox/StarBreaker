    #[test]
    fn compile_ir_adds_primary_state_tag_alongside_authored_style_tags() {
        let canvas = serde_json::json!({
            "_RecordName_": "BuildingBlocks_Canvas.PrimaryStateStyleTags",
            "_RecordValue_": {
                "size": {"x": 100, "y": 100},
                "scene": [
                    {
                        "_Pointer_": "ptr:1",
