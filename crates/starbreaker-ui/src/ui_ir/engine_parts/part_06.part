        );

        let node = ir
            .nodes
            .iter()
            .find(|node| node.name == "machine_type")
            .expect("machine_type node");
        assert_eq!(
            node.text_style.as_ref().map(|style| &style.font_size),
            Some(&UiIrValue::Fixed { value: 41.0 })
        );
    }

